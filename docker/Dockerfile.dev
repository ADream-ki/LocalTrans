# 开发环境
FROM python:3.11-slim

WORKDIR /app

# 安装系统依赖
RUN apt-get update && apt-get install -y \
    portaudio19-dev \
    libsndfile1 \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

# 复制依赖文件
COPY pyproject.toml .
COPY src/ ./src/

# 安装依赖
RUN pip install --upgrade pip && \
    pip install -e ".[full,dev]"

# 创建数据目录
RUN mkdir -p /root/.localtrans/models /root/.localtrans/logs /root/.localtrans/cache

CMD ["python", "-m", "localtrans.main", "--help"]