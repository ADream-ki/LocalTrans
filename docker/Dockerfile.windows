# Dockerfile for building Windows EXE using Windows container
# 需要在 Windows 上运行

FROM mcr.microsoft.com/windows/python:3.11-windowsservercore

WORKDIR /build

# 安装依赖
COPY pyproject.toml .
COPY src/ ./src/
COPY pytest.ini .

RUN pip install --upgrade pip && \
    pip install pyinstaller && \
    pip install -e ".[asr,mt,tts,gui]"

# 复制打包配置
COPY localtrans.spec .

# 打包
RUN pyinstaller localtrans.spec --noconfirm

# 输出目录
VOLUME C:/build/dist

CMD ["cmd"]
